---
import type { Lang } from '../../i18n/languages';
import { supportedLangs } from '../../i18n/languages';
import { useTranslation } from '../../i18n/utils';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { siteConfig } from '../../data/siteConfig';

export function getStaticPaths() {
  return supportedLangs.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslation(lang);
const currentPath = Astro.url.pathname;
---

<BaseLayout lang={lang} title={`${t('contact.title')} — Charbel Matta`}>
  <Header lang={lang} currentPath={currentPath} />

  <main id="main-content" class="pt-32 pb-20">
    <div class="max-w-[1440px] mx-auto px-8 md:px-16">
      <!-- Header -->
      <div class="flex flex-col items-center mb-8">
        <h1 class="font-serif text-[48px] leading-[1.2] tracking-[-0.01em] text-primary mb-4">{t('contact.title')}</h1>
        <div class="w-12 h-px bg-tertiary-fixed-dim"></div>
      </div>

      <!-- 12-col grid: 7 cols form, 5 cols info -->
      <section class="py-32 border-t border-outline-variant/30">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
          <!-- Form (7 cols) -->
          <div class="lg:col-span-7">
            <form action={siteConfig.formspreeContact} method="POST" class="space-y-0">
              <!-- 2-col name/email -->
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
                <div>
                  <label for="name" class="form-label">{t('contact.name')}</label>
                  <input type="text" id="name" name="name" required class="form-input" placeholder={t('contact.name')} />
                </div>
                <div>
                  <label for="email" class="form-label">{t('contact.email')}</label>
                  <input type="email" id="email" name="email" required class="form-input" placeholder={t('contact.email')} />
                </div>
              </div>
              <!-- Full-width subject -->
              <div class="mb-8">
                <label for="subject" class="form-label">{t('contact.subject')}</label>
                <select id="subject" name="subject" required class="form-input bg-transparent cursor-pointer">
                  <option value="">{t('contact.subject')}</option>
                  <option value="general">{t('contact.subject_general')}</option>
                  <option value="exhibition">{t('contact.subject_exhibition')}</option>
                  <option value="press">{t('contact.subject_press')}</option>
                  <option value="acquisition">{t('contact.subject_acquisition')}</option>
                </select>
              </div>
              <!-- Full-width message -->
              <div class="mb-10">
                <label for="message" class="form-label">{t('contact.message')}</label>
                <textarea id="message" name="message" rows="6" required class="form-input resize-none" placeholder={t('contact.message')}></textarea>
              </div>
              <!-- Submit button with arrow -->
              <button
                type="submit"
                class="inline-flex items-center justify-center gap-3 px-8 py-4 border border-primary-container text-primary-container label-caps hover:bg-primary-container hover:text-on-primary transition-colors duration-300 tracking-widest group"
              >
                {t('contact.send')}
                <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
              </button>
            </form>
          </div>

          <!-- Info (5 cols) -->
          <div class="lg:col-span-5 space-y-10">
            <!-- Informations Directes -->
            <div>
              <h3 class="label-caps text-tertiary-fixed-dim tracking-widest mb-6">
                {lang === 'fr' ? 'Informations Directes' : lang === 'ar' ? 'معلومات مباشرة' : 'Direct Information'}
              </h3>
              <div class="space-y-6">
                <a href={`mailto:${siteConfig.email}`} class="flex items-start gap-4 group">
                  <div class="w-10 h-10 flex items-center justify-center bg-surface-container-low flex-shrink-0">
                    <svg class="w-5 h-5 text-tertiary-fixed-dim" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                    </svg>
                  </div>
                  <div>
                    <span class="label-caps text-outline tracking-widest">{t('contact.email')}</span>
                    <p class="text-[16px] text-primary group-hover:text-tertiary transition-colors duration-300 mt-1">{siteConfig.email}</p>
                  </div>
                </a>
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 flex items-center justify-center bg-surface-container-low flex-shrink-0">
                    <svg class="w-5 h-5 text-tertiary-fixed-dim" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0z" />
                    </svg>
                  </div>
                  <div>
                    <span class="label-caps text-outline tracking-widest">{lang === 'fr' ? 'Adresse' : lang === 'ar' ? 'العنوان' : 'Address'}</span>
                    <p class="text-[16px] text-on-surface-variant mt-1">{t('contact.location')}</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Affiliation card -->
            <div class="bg-surface-container-low p-8">
              <h3 class="label-caps text-tertiary-fixed-dim tracking-widest mb-4">
                {lang === 'fr' ? 'Affiliation' : lang === 'ar' ? 'الانتماء' : 'Affiliation'}
              </h3>
              <p class="text-[16px] text-on-surface-variant">{t('contact.affiliation')}</p>
            </div>

            <!-- Reseaux / Social -->
            <div>
              <h3 class="label-caps text-tertiary-fixed-dim tracking-widest mb-6">
                {lang === 'fr' ? 'Reseaux' : lang === 'ar' ? 'شبكات التواصل' : 'Social'}
              </h3>
              <div class="flex items-center gap-4">
                {siteConfig.social.youtube && (
                  <a href={siteConfig.social.youtube} target="_blank" rel="noopener noreferrer" class="w-10 h-10 flex items-center justify-center bg-surface-container-low text-on-surface-variant hover:text-tertiary-fixed-dim hover:bg-surface-container transition-all duration-300" aria-label="YouTube">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                  </a>
                )}
                {siteConfig.social.instagram && (
                  <a href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer" class="w-10 h-10 flex items-center justify-center bg-surface-container-low text-on-surface-variant hover:text-tertiary-fixed-dim hover:bg-surface-container transition-all duration-300" aria-label="Instagram">
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
                  </a>
                )}
              </div>
            </div>

            <!-- Professional note -->
            <div class="border-t border-outline-variant/30 pt-6">
              <p class="text-[14px] leading-[1.6] text-on-surface-variant italic">{t('contact.professional_note')}</p>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>

  <Footer lang={lang} />
</BaseLayout>
