---
import { getCollection } from 'astro:content';
import type { Lang } from '../../i18n/languages';
import { supportedLangs } from '../../i18n/languages';
import { useTranslation, getLocalizedContent } from '../../i18n/utils';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export function getStaticPaths() {
  return supportedLangs.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslation(lang);
const currentPath = Astro.url.pathname;

const allPubs = await getCollection('publications');
const featured = allPubs.find(p => p.data.featured);
const articles = allPubs.filter(p => !p.data.featured && p.data.type !== 'collection');
const collection = allPubs.find(p => p.data.type === 'collection');
---

<BaseLayout lang={lang} title={`${t('publications.title')} — Charbel Matta`}>
  <Header lang={lang} currentPath={currentPath} />

  <main id="main-content" class="pt-32 pb-20">
    <div class="max-w-[1440px] mx-auto px-8 md:px-16">
      <!-- Header -->
      <div class="flex flex-col items-center mb-8">
        <h1 class="font-serif text-[48px] leading-[1.2] tracking-[-0.01em] text-primary mb-4">{t('publications.title')}</h1>
        <div class="w-12 h-px bg-tertiary-fixed-dim"></div>
      </div>

      <!-- Featured Book -->
      {featured && (
        <section class="py-32 border-t border-outline-variant/30">
          <span class="label-caps text-tertiary-fixed-dim tracking-widest mb-10 block">{t('publications.featured')}</span>
          <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
            <!-- Book cover -->
            <div class="md:col-span-5">
              <div class="aspect-[3/4] bg-surface shadow-2xl p-4 transform -rotate-2 hover:rotate-0 transition-transform duration-500">
                <div class="w-full h-full bg-surface-container-high flex items-center justify-center">
                  <svg class="w-16 h-16 text-outline-variant" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
                </div>
              </div>
            </div>
            <!-- Book details -->
            <div class="md:col-span-7 md:pl-8">
              {featured.data.award && (
                <span class="inline-block px-3 py-1 border border-tertiary-fixed-dim text-tertiary label-caps tracking-widest bg-surface mb-6">{featured.data.award}</span>
              )}
              <h2 class="font-serif text-[48px] leading-[1.2] tracking-[-0.01em] text-primary mb-6">{getLocalizedContent(featured.data.title, lang)}</h2>

              <!-- Metadata grid -->
              <div class="grid grid-cols-2 gap-y-4 gap-x-8 mb-8">
                <div>
                  <span class="label-caps text-outline tracking-widest">{t('publications.authors')}</span>
                  <p class="text-[16px] text-on-surface-variant mt-1">{featured.data.authors.join(', ')}</p>
                </div>
                {featured.data.publisher && (
                  <div>
                    <span class="label-caps text-outline tracking-widest">{t('publications.publisher')}</span>
                    <p class="text-[16px] text-on-surface-variant mt-1">{featured.data.publisher}</p>
                  </div>
                )}
                <div>
                  <span class="label-caps text-outline tracking-widest">{t('publications.year')}</span>
                  <p class="text-[16px] text-on-surface-variant mt-1">{featured.data.year}</p>
                </div>
                {featured.data.isbn && (
                  <div>
                    <span class="label-caps text-outline tracking-widest">{t('publications.isbn')}</span>
                    <p class="text-[16px] text-on-surface-variant mt-1">{featured.data.isbn}</p>
                  </div>
                )}
              </div>

              {featured.data.description && (
                <p class="text-[18px] leading-[1.6] text-on-surface-variant mb-8">{getLocalizedContent(featured.data.description, lang)}</p>
              )}

              <div class="flex flex-wrap gap-4">
                {featured.data.buyLink && (
                  <a href={featured.data.buyLink} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center px-8 py-4 border border-primary-container text-primary-container label-caps hover:bg-primary-container hover:text-on-primary transition-colors duration-300 tracking-widest">
                    {t('publications.buy')}
                  </a>
                )}
              </div>
            </div>
          </div>
        </section>
      )}

      <!-- Articles & Chapters -->
      {articles.length > 0 && (
        <section class="py-32 border-t border-outline-variant/30">
          <div class="flex items-center gap-4 mb-12">
            <span class="label-caps text-tertiary-fixed-dim tracking-widest">{t('publications.articles_chapters')}</span>
            <div class="flex-1 h-px bg-outline-variant/30"></div>
          </div>
          <div class="space-y-0">
            {articles.map((pub) => (
              <div class="flex flex-col md:flex-row md:items-center justify-between py-6 border-b border-outline-variant/20 group">
                <div class="flex-1">
                  <h3 class="font-serif text-[24px] leading-[1.3] text-primary group-hover:text-tertiary transition-colors duration-300">{getLocalizedContent(pub.data.title, lang)}</h3>
                  <p class="text-[14px] text-on-surface-variant mt-1">{pub.data.authors.join(', ')}</p>
                </div>
                <div class="mt-3 md:mt-0 md:text-right flex-shrink-0 md:ml-8">
                  {pub.data.publisher && <p class="text-[14px] text-on-surface-variant">{pub.data.publisher}</p>}
                  <p class="label-caps text-outline tracking-widest mt-1">{pub.data.year}</p>
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Postcard Collection -->
      {collection && (
        <section class="py-32 border-t border-outline-variant/30">
          <div class="flex items-center gap-4 mb-12">
            <span class="label-caps text-tertiary-fixed-dim tracking-widest">{t('publications.postcard_collection')}</span>
            <div class="flex-1 h-px bg-outline-variant/30"></div>
          </div>
          <div class="bg-surface-container-low p-12 md:p-20">
            <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-center">
              <div class="md:col-span-7">
                <h2 class="font-serif text-[32px] leading-[1.3] text-primary mb-6">{getLocalizedContent(collection.data.title, lang)}</h2>
                {collection.data.description && (
                  <p class="text-[18px] leading-[1.6] text-on-surface-variant">{getLocalizedContent(collection.data.description, lang)}</p>
                )}
              </div>
              <!-- Horizontal scroll hint for postcards -->
              <div class="md:col-span-5">
                <div class="flex gap-4 overflow-x-auto pb-4 -mx-4 px-4">
                  {[1, 2, 3].map(() => (
                    <div class="flex-shrink-0 w-40 aspect-[3/2] bg-surface-container-high flex items-center justify-center">
                      <svg class="w-8 h-8 text-outline-variant" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" /></svg>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </section>
      )}
    </div>
  </main>

  <Footer lang={lang} />
</BaseLayout>
