---
import { getCollection } from 'astro:content';
import type { Lang } from '../../i18n/languages';
import { supportedLangs } from '../../i18n/languages';
import { useTranslation, getLocalizedContent } from '../../i18n/utils';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

export function getStaticPaths() {
  return supportedLangs.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslation(lang);
const currentPath = Astro.url.pathname;

const allPress = await getCollection('press');
const articles = allPress.filter(p => p.data.type === 'article').sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const videos = allPress.filter(p => p.data.type === 'video' || p.data.type === 'tv').sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout lang={lang} title={`${t('press.title')} — Charbel Matta`}>
  <Header lang={lang} currentPath={currentPath} />

  <main id="main-content" class="pt-32 pb-20">
    <div class="max-w-[1440px] mx-auto px-8 md:px-16">
      <!-- Header -->
      <div class="flex flex-col items-center mb-8">
        <h1 class="font-serif text-[48px] leading-[1.2] tracking-[-0.01em] text-primary mb-4">{t('press.title')}</h1>
        <div class="w-12 h-px bg-tertiary-fixed-dim"></div>
      </div>

      <!-- Articles -->
      <section class="py-32 border-t border-outline-variant/30">
        <div class="space-y-0">
          {articles.map((item) => (
            <a
              href={item.data.url || '#'}
              target={item.data.url ? '_blank' : undefined}
              rel={item.data.url ? 'noopener noreferrer' : undefined}
              class="flex flex-col md:flex-row md:items-center justify-between py-8 border-b border-outline-variant/20 group transition-colors duration-300 hover:bg-surface-container-low/50 -mx-4 px-4"
            >
              <div class="flex-1">
                <h2 class="font-serif text-[24px] leading-[1.3] text-primary group-hover:text-tertiary transition-colors duration-300">{getLocalizedContent(item.data.title, lang)}</h2>
                {item.data.excerpt && (
                  <p class="text-[14px] leading-[1.6] text-on-surface-variant mt-2 max-w-2xl">{getLocalizedContent(item.data.excerpt, lang)}</p>
                )}
              </div>
              <div class="mt-4 md:mt-0 md:text-right flex-shrink-0 md:ml-12 flex flex-col items-start md:items-end gap-2">
                <span class="text-[14px] text-on-surface-variant">{item.data.publication}</span>
                <span class="label-caps text-outline tracking-widest">
                  {new Date(item.data.date).toLocaleDateString(lang === 'fr' ? 'fr-FR' : lang === 'ar' ? 'ar-LB' : 'en-US', { month: 'long', year: 'numeric' })}
                </span>
                {item.data.url && (
                  <span class="inline-flex items-center text-primary-container label-caps tracking-widest group-hover:text-tertiary transition-colors duration-300">
                    {t('press.read_article')}
                    <svg class="w-3 h-3 ml-1 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg>
                  </span>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- Videos -->
      {videos.length > 0 && (
        <section class="py-32 border-t border-outline-variant/30">
          <div class="flex items-center gap-4 mb-12">
            <span class="label-caps text-tertiary-fixed-dim tracking-widest">{t('press.videos')}</span>
            <div class="flex-1 h-px bg-outline-variant/30"></div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {videos.map((item) => (
              <a
                href={item.data.url || '#'}
                target={item.data.url ? '_blank' : undefined}
                rel={item.data.url ? 'noopener noreferrer' : undefined}
                class="group"
              >
                <div class="aspect-video overflow-hidden bg-surface-variant mb-4">
                  <div class="w-full h-full bg-surface-container-high flex items-center justify-center transition-transform duration-700 group-hover:scale-105 relative">
                    <svg class="w-12 h-12 text-outline-variant" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" /></svg>
                    <!-- Play icon overlay -->
                    <div class="absolute inset-0 flex items-center justify-center">
                      <div class="w-16 h-16 rounded-full bg-primary/80 flex items-center justify-center group-hover:bg-tertiary-fixed-dim/90 transition-colors duration-300">
                        <svg class="w-6 h-6 text-on-primary ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                      </div>
                    </div>
                  </div>
                </div>
                <h3 class="font-serif text-[18px] leading-[1.4] text-primary group-hover:text-tertiary transition-colors duration-300">{getLocalizedContent(item.data.title, lang)}</h3>
                <div class="flex items-center gap-3 mt-2">
                  <span class="text-[14px] text-on-surface-variant">{item.data.publication}</span>
                  <span class="text-outline-variant">|</span>
                  <span class="label-caps text-outline tracking-widest">
                    {new Date(item.data.date).toLocaleDateString(lang === 'fr' ? 'fr-FR' : lang === 'ar' ? 'ar-LB' : 'en-US', { month: 'long', year: 'numeric' })}
                  </span>
                </div>
              </a>
            ))}
          </div>
        </section>
      )}
    </div>
  </main>

  <Footer lang={lang} />
</BaseLayout>
