---
import { languages, type Lang } from '../i18n/languages';

interface Props {
  currentLang: Lang;
  currentPath: string;
}

const { currentLang, currentPath } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function getPathInLang(targetLang: string): string {
  const pathWithoutBase = currentPath.startsWith(base) ? currentPath.slice(base.length) : currentPath;
  const segments = pathWithoutBase.split('/').filter(Boolean);
  if (segments[0] && Object.keys(languages).includes(segments[0])) {
    segments[0] = targetLang;
  } else {
    segments.unshift(targetLang);
  }
  return base + '/' + segments.join('/') + '/';
}
---

<nav aria-label="Language switcher" class="flex items-center gap-1.5">
  {Object.entries(languages).map(([code, _config], i) => (
    <>
      {i > 0 && <span class="text-outline-variant text-xs" aria-hidden="true">|</span>}
      <a
        href={getPathInLang(code)}
        class:list={[
          'px-1 py-0.5 transition-colors text-sm',
          code === currentLang
            ? 'font-serif text-primary font-medium'
            : 'text-outline hover:text-primary',
        ]}
        aria-current={code === currentLang ? 'true' : undefined}
        lang={code}
        data-lang-switch={code}
      >
        {code.toUpperCase()}
      </a>
    </>
  ))}
</nav>

<script>
  document.querySelectorAll('[data-lang-switch]').forEach((link) => {
    link.addEventListener('click', () => {
      const lang = (link as HTMLElement).dataset.langSwitch;
      if (lang) localStorage.setItem('charbel-lang', lang);
    });
  });
</script>
