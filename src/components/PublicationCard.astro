---
import type { Lang } from '../i18n/languages';
import { getLocalizedContent, useTranslation } from '../i18n/utils';

interface Props {
  title: { fr: string; en: string; ar: string };
  type: 'book' | 'chapter' | 'collection';
  authors: string[];
  publisher?: string;
  year: number;
  isbn?: string;
  description?: { fr: string; en: string; ar: string };
  award?: string;
  featured?: boolean;
  lang: Lang;
}

const { title, authors, publisher, year, isbn, description, award, featured = false, lang } = Astro.props;
const t = useTranslation(lang);
const localizedTitle = getLocalizedContent(title, lang);
const localizedDescription = description ? getLocalizedContent(description, lang) : '';
---

{featured ? (
  <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 items-start">
    <!-- Book cover with matting -->
    <div class="md:col-span-5">
      <div class="bg-surface-container-low p-4">
        <div class="aspect-[3/4] bg-surface-container-high shadow-2xl flex items-center justify-center">
          <svg class="w-12 h-12 text-outline-variant/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" />
          </svg>
        </div>
      </div>
    </div>

    <!-- Text content -->
    <div class="md:col-span-7 flex flex-col justify-center">
      {award && (
        <span class="inline-block border border-tertiary-fixed-dim text-tertiary label-caps px-3 py-1.5 mb-4 self-start">
          {award}
        </span>
      )}
      <h3 class="font-serif text-2xl md:text-[32px] text-primary font-normal leading-tight">{localizedTitle}</h3>

      <!-- Metadata grid -->
      <div class="mt-6 space-y-3">
        <div class="flex gap-4">
          <span class="label-caps text-outline min-w-[5rem]">{t('publications.authors') || 'Authors'}</span>
          <span class="text-on-surface-variant">{authors.join(', ')}</span>
        </div>
        {publisher && (
          <div class="flex gap-4">
            <span class="label-caps text-outline min-w-[5rem]">{t('publications.publisher') || 'Publisher'}</span>
            <span class="text-on-surface-variant">{publisher}, {year}</span>
          </div>
        )}
        {isbn && (
          <div class="flex gap-4">
            <span class="label-caps text-outline min-w-[5rem]">ISBN</span>
            <span class="text-on-surface-variant text-sm">{isbn}</span>
          </div>
        )}
      </div>

      {localizedDescription && (
        <p class="text-on-surface-variant mt-6 leading-relaxed">{localizedDescription}</p>
      )}

      <!-- Outlined button -->
      <a
        href="#"
        class="inline-flex items-center gap-2 border border-primary-container text-primary-container label-caps tracking-widest px-6 py-3 mt-8 transition-colors hover:bg-primary-container hover:text-on-primary self-start"
      >
        {t('publications.view_details') || 'View Details'}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
) : (
  <div class="py-4 border-b border-outline-variant/20">
    <h4 class="font-medium text-primary">{localizedTitle}</h4>
    <p class="text-on-surface-variant text-sm mt-1">{authors.join(', ')}{publisher ? ` — ${publisher}` : ''}, {year}</p>
  </div>
)}
