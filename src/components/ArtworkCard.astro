---
import type { Lang } from '../i18n/languages';
import { getLocalizedContent } from '../i18n/utils';

interface Props {
  title: { fr: string; en: string; ar: string };
  year: number;
  medium: string;
  image: string;
  dimensions?: string;
  lang: Lang;
  index: number;
}

const { title, year, medium, image, lang, index } = Astro.props;
const localizedTitle = getLocalizedContent(title, lang);
---

<button
  class="bg-surface-container-low p-4 artwork-hover group cursor-pointer w-full text-left"
  data-lightbox-trigger={index}
  aria-label={localizedTitle}
>
  <div class="w-full aspect-square relative overflow-hidden bg-surface-container">
    <!-- Placeholder icon (shown behind image) -->
    <div class="absolute inset-0 flex items-center justify-center">
      <svg class="w-12 h-12 text-outline-variant/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
        <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909M3.75 21h16.5A2.25 2.25 0 0 0 22.5 18.75V5.25A2.25 2.25 0 0 0 20.25 3H3.75A2.25 2.25 0 0 0 1.5 5.25v13.5A2.25 2.25 0 0 0 3.75 21Z" />
      </svg>
    </div>

    <!-- Hover overlay -->
    <div class="hover-content absolute inset-0 bg-primary/80 flex flex-col items-center justify-center p-6 z-10">
      <p class="font-serif text-lg text-white text-center">{localizedTitle}</p>
      <p class="text-surface-variant italic text-sm mt-2">{year}</p>
    </div>
  </div>
</button>
