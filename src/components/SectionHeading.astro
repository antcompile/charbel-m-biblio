---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
}

const { title, subtitle, align = 'center' } = Astro.props;
---

{align === 'center' ? (
  <div class="text-center mb-16">
    <h2 class="font-serif text-3xl md:text-[32px] text-primary font-normal">{title}</h2>
    <div class="w-12 h-px bg-tertiary-fixed-dim mx-auto mt-4"></div>
    {subtitle && <p class="mt-4 text-on-surface-variant text-lg max-w-2xl mx-auto">{subtitle}</p>}
  </div>
) : (
  <div class="mb-16 border-b border-surface-variant pb-4">
    <h2 class="font-serif text-3xl md:text-[32px] text-primary font-normal">{title}</h2>
    {subtitle && <p class="mt-3 text-on-surface-variant text-lg max-w-2xl">{subtitle}</p>}
  </div>
)}
