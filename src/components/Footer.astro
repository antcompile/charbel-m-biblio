---
import type { Lang } from '../i18n/languages';
import { useTranslation } from '../i18n/utils';
import { siteConfig } from '../data/siteConfig';
import { mainNav } from '../data/navigation';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslation(lang);

const navLinks = mainNav.filter(item => item.key !== 'nav.home');
---

<footer class="bg-[#1a1a2e] border-t border-white/10">
  <div class="max-w-[1440px] mx-auto px-6 md:px-16 py-20">
    <div class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-3 md:gap-16">
      <!-- Brand -->
      <div class="space-y-4">
        <div class="font-serif text-amber-400 text-2xl tracking-widest uppercase">Charbel Matta</div>
        <p class="text-stone-400 text-sm leading-relaxed font-sans">{t('hero.tagline')}</p>
      </div>

      <!-- Navigation -->
      <div>
        <h4 class="label-caps text-stone-200 mb-6">{t('footer.navigation_heading')}</h4>
        <ul class="space-y-3">
          {navLinks.map((item) => (
            <li>
              <a href={item.href(lang)} class="text-stone-400 hover:text-white transition-colors text-sm">
                {t(item.key)}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="label-caps text-stone-200 mb-6">{t('footer.contact_heading')}</h4>
        <ul class="space-y-4 text-sm">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-amber-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
            <a href={`mailto:${siteConfig.email}`} class="text-stone-400 hover:text-white transition-colors">{siteConfig.email}</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-amber-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0z" />
            </svg>
            <span class="text-stone-400">{t('contact.location')}</span>
          </li>
        </ul>
        <!-- Social -->
        <div class="flex items-center gap-4 mt-6">
          {siteConfig.social.youtube && (
            <a href={siteConfig.social.youtube} target="_blank" rel="noopener noreferrer" class="text-stone-400 hover:text-white transition-colors" aria-label="YouTube">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            </a>
          )}
        </div>
      </div>
    </div>

    <!-- Copyright bar -->
    <div class="mt-16 pt-8 border-t border-stone-800 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-stone-400 font-sans tracking-wide text-sm">{t('footer.copyright')}</p>
    </div>
  </div>
</footer>
