---
import type { Lang } from '../i18n/languages';
import { getLocalizedContent, useTranslation } from '../i18n/utils';

interface Props {
  title: { fr: string; en: string; ar: string };
  publication: string;
  date: string;
  url?: string;
  excerpt?: { fr: string; en: string; ar: string };
  type: 'article' | 'video' | 'tv';
  lang: Lang;
}

const { title, publication, date, url, excerpt, type, lang } = Astro.props;
const t = useTranslation(lang);
const localizedTitle = getLocalizedContent(title, lang);
const localizedExcerpt = excerpt ? getLocalizedContent(excerpt, lang) : '';
const formattedDate = new Date(date).toLocaleDateString(lang === 'ar' ? 'ar-LB' : lang === 'fr' ? 'fr-FR' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<div class="py-6 border-b border-outline-variant/20 flex items-start justify-between gap-6 group">
  <div class="flex-1 min-w-0">
    <!-- Publication name -->
    <span class="label-caps text-tertiary-fixed-dim">{publication}</span>

    <!-- Title -->
    {url ? (
      <a
        href={url}
        target="_blank"
        rel="noopener noreferrer"
        class="block mt-2 text-lg text-primary hover:text-secondary transition-colors leading-snug"
      >
        {localizedTitle}
      </a>
    ) : (
      <h3 class="mt-2 text-lg text-primary leading-snug">{localizedTitle}</h3>
    )}

    <!-- Date -->
    <p class="caption text-outline mt-2">{formattedDate}</p>

    {localizedExcerpt && (
      <p class="text-on-surface-variant text-sm mt-3 leading-relaxed">{localizedExcerpt}</p>
    )}
  </div>

  <!-- External link arrow -->
  {url && (
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class="flex-shrink-0 text-outline hover:text-primary transition-colors mt-2"
      aria-label={localizedTitle}
    >
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
      </svg>
    </a>
  )}
</div>
